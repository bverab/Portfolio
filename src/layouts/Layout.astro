---
import "@fontsource-variable/onest"
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import { ViewTransitions } from "astro:transitions"
import "../styles/global.css";

interface Props {
  title: string
  description: string
}

const { description, title } = Astro.props
const siteUrl = "https://portfolio-ten-olive-65.vercel.app"
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Bastián Vera Benavides" />

    <!-- Open Graph (WhatsApp, LinkedIn, Facebook, iMessage) -->
    <meta property="og:type"         content="website" />
    <meta property="og:url"          content={siteUrl} />
    <meta property="og:title"        content={title} />
    <meta property="og:description"  content={description} />
    <meta property="og:image"        content={`${siteUrl}/og-image.png`} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt"    content="Portfolio de Bastián Vera — Data Scientist" />
    <meta property="og:locale"       content="es_CL" />
    <meta property="og:site_name"    content="Bastián Vera · Portfolio" />

    <!-- Twitter / X -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={`${siteUrl}/og-image.png`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <ViewTransitions />
  </head>
  <body>
    <!-- Fondo degradado cyan/turquesa -->
    <div class="fixed inset-0 -z-10 [background:radial-gradient(125%_125%_at_50%_10%,#000_50%,#0af_100%)]"></div>

    <!-- Canvas estrellas fugaces — detrás de todo el contenido -->
    <canvas id="shooting-stars" class="fixed inset-0 -z-10 pointer-events-none"></canvas>

    <!-- Contenido -->
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<script>
  const canvas = document.getElementById("shooting-stars") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;

  function resize() {
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener("resize", resize);

  interface Star {
    x: number;
    y: number;
    len: number;
    speed: number;
    angle: number;
    opacity: number;
    width: number;
    life: number;
    maxLife: number;
  }

  const stars: Star[] = [];
  const MAX_STARS = 4;

  function randomStar(): Star {
    const angleDeg = 25 + Math.random() * 15;
    const angle    = (angleDeg * Math.PI) / 180;
    const fromTop  = Math.random() > 0.4;
    const x = fromTop ? Math.random() * canvas.width : 0;
    const y = fromTop ? 0 : Math.random() * canvas.height * 0.5;
    return {
      x, y,
      len:     120 + Math.random() * 180,
      speed:   4 + Math.random() * 4,
      angle,
      opacity: 0,
      width:   0.6 + Math.random() * 0.8,
      life:    0,
      maxLife: 90 + Math.random() * 60,
    };
  }

  let frameCount = 0;

  function spawnIfNeeded() {
    if (stars.length < MAX_STARS && Math.random() < 0.008) {
      stars.push(randomStar());
    }
  }

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    spawnIfNeeded();

    for (let i = stars.length - 1; i >= 0; i--) {
      const s = stars[i];
      s.life++;

      const progress = s.life / s.maxLife;
      if (progress < 0.2)       s.opacity = progress / 0.2;
      else if (progress > 0.7)  s.opacity = 1 - (progress - 0.7) / 0.3;
      else                      s.opacity = 1;

      s.x += Math.cos(s.angle) * s.speed;
      s.y += Math.sin(s.angle) * s.speed;

      const headX = s.x;
      const headY = s.y;
      const tailX = headX - Math.cos(s.angle) * s.len;
      const tailY = headY - Math.sin(s.angle) * s.len;

      const grad = ctx.createLinearGradient(tailX, tailY, headX, headY);
      grad.addColorStop(0,   `rgba(0, 220, 255, 0)`);
      grad.addColorStop(0.6, `rgba(0, 220, 255, ${s.opacity * 0.25})`);
      grad.addColorStop(1,   `rgba(180, 240, 255, ${s.opacity * 0.9})`);

      ctx.beginPath();
      ctx.moveTo(tailX, tailY);
      ctx.lineTo(headX, headY);
      ctx.strokeStyle = grad;
      ctx.lineWidth   = s.width;
      ctx.lineCap     = "round";
      ctx.stroke();

      const glow = ctx.createRadialGradient(headX, headY, 0, headX, headY, 3);
      glow.addColorStop(0, `rgba(180, 240, 255, ${s.opacity * 0.8})`);
      glow.addColorStop(1, `rgba(0, 220, 255, 0)`);
      ctx.beginPath();
      ctx.arc(headX, headY, 3, 0, Math.PI * 2);
      ctx.fillStyle = glow;
      ctx.fill();

      if (s.life >= s.maxLife || s.x > canvas.width + 50 || s.y > canvas.height + 50) {
        stars.splice(i, 1);
      }
    }

    frameCount++;
    requestAnimationFrame(draw);
  }

  draw();
</script>

<style is:global>
  :root {
    color-scheme: dark;
    --font-primary: "Onest Variable", sans-serif;
  }

  html, body {
    margin: 0;
    width: 100%;
    color: white;
    min-height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  main {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
</style>