---
import GitHub from "./icons/GitHub.astro";
import LinkedIn from "./icons/LinkedIn.astro";
import Mail from "./icons/Mail.astro";

const year = new Date().getFullYear();
---

<footer class="w-full mt-10">
  <div class="w-full py-10">
    <div class="max-w-6xl mx-auto px-6">

      <!-- Línea dentro del contenedor -->
      <div class="w-full h-px bg-white/8 mb-10"></div>

      <!-- 3 columnas: iconos | quote | luna — apiladas en móvil -->
      <div class="flex flex-col items-center gap-8 mb-10 sm:flex-row sm:items-center sm:justify-between">

        <!-- Izquierda: iconos -->
        <div class="flex items-center gap-6">
          <a href="https://github.com/bverab" target="_blank" rel="noopener noreferrer"
            aria-label="GitHub" class="footer-icon">
            <GitHub width="28" height="28" />
          </a>
          <a href="https://linkedin.com/in/bverab" target="_blank" rel="noopener noreferrer"
            aria-label="LinkedIn" class="footer-icon">
            <LinkedIn width="28" height="28" />
          </a>
          <a href="https://mail.google.com/mail/?view=cm&to=bastianverab@gmail.com" target="_blank" rel="noopener noreferrer"
            aria-label="Email" class="footer-icon">
            <Mail width="28" height="28" />
          </a>
        </div>

        <!-- Centro: quote — sin bordes laterales en móvil -->
        <div class="quote-box w-full text-center px-4 sm:flex-1 sm:px-8">
          <p class="text-sm font-medium leading-relaxed italic quote-text"></p>
          <p class="text-xs mt-1.5 quote-author"></p>
        </div>

        <!-- Derecha: widget fase lunar -->
        <div class="moon-widget flex flex-col items-center gap-3">
          <canvas id="moon-canvas" width="72" height="72"></canvas>
          <div class="text-center">
            <p class="text-xs text-white/20 uppercase tracking-widest">Fase lunar</p>
            <p id="moon-name" class="text-xs text-white/40 mt-0.5 font-medium"></p>
          </div>
        </div>

      </div>

      <!-- Línea inferior + copyright -->
      <div class="w-full h-px bg-white/8 mb-6"></div>
      <p class="text-center text-xs text-white/20">
        © {year} Bastián Vera Benavides. Todos los derechos reservados.
      </p>

    </div>
  </div>
</footer>

<script>
  /* ── Quotes ── */
  const quotes = [
    { text: "El universo no solo es más extraño de lo que suponemos, sino más extraño de lo que podemos suponer.", author: "— J.B.S. Haldane" },
    { text: "Mira de nuevo ese punto. Eso es aquí. Eso es casa. Eso somos nosotros.", author: "— Carl Sagan, Pale Blue Dot" },
    { text: "La astronomía es una ciencia humillante y edificante a la vez.", author: "— Carl Sagan" },
    { text: "Somos una forma en que el cosmos se conoce a sí mismo.", author: "— Carl Sagan" },
    { text: "Dios no juega a los dados con el universo.", author: "— Albert Einstein" },
    { text: "Dos cosas son infinitas: el universo y la estupidez humana; y del universo no estoy seguro.", author: "— Albert Einstein" },
    { text: "La imaginación es más importante que el conocimiento.", author: "— Albert Einstein" },
    { text: "Si las estrellas aparecieran solo una noche cada mil años, ¿cómo creerían los hombres y adorarían?", author: "— Ralph Waldo Emerson" },
    { text: "No somos solo observadores del universo, somos participantes.", author: "— John Archibald Wheeler" },
    { text: "El universo no tiene ninguna obligación de tener sentido para ti.", author: "— Neil deGrasse Tyson" },
    { text: "La física es el universo escribiéndose a sí mismo en el lenguaje de las matemáticas.", author: "— Richard Feynman" },
    { text: "Alcanzar las estrellas es quizás la única forma en que podemos convertirnos en inmortales.", author: "— Freeman Dyson" },
    { text: "Los datos son lo que distingue el balbuceo de la ciencia.", author: "— Carl Sagan" },
  ];

  const q = quotes[Math.floor(Math.random() * quotes.length)];
  const textEl = document.querySelector<HTMLElement>(".quote-text");
  const authEl = document.querySelector<HTMLElement>(".quote-author");
  if (textEl) textEl.textContent = `"${q.text}"`;
  if (authEl) authEl.textContent = q.author;

  /* ── Fase lunar ── */
  function getMoonPhase(date: Date): { phase: number; name: string } {
    const year  = date.getFullYear();
    const month = date.getMonth() + 1;
    const day   = date.getDate();
    let y = year, m = month;
    if (m < 3) { y--; m += 12; }
    const a  = Math.floor(y / 100);
    const b  = 2 - a + Math.floor(a / 4);
    const jd = Math.floor(365.25 * (y + 4716)) + Math.floor(30.6001 * (m + 1)) + day + b - 1524.5;
    const phase = ((jd - 2451550.1) / 29.530588) % 1;
    const p = phase < 0 ? phase + 1 : phase;
    const names = [
      "Luna nueva", "Creciente iluminante", "Cuarto creciente", "Gibosa creciente",
      "Luna llena", "Gibosa menguante", "Cuarto menguante", "Creciente menguante",
    ];
    return { phase: p, name: names[Math.round(p * 8) % 8] };
  }

  function drawMoon(canvas: HTMLCanvasElement, phase: number) {
    const ctx = canvas.getContext("2d")!;
    const size = canvas.width;
    const cx = size / 2, cy = size / 2, r = size / 2 - 4;
    ctx.clearRect(0, 0, size, size);

    ctx.beginPath();
    ctx.arc(cx, cy, r, 0, Math.PI * 2);
    ctx.fillStyle = "rgba(10, 10, 20, 0.85)";
    ctx.fill();
    ctx.strokeStyle = "rgba(34, 211, 238, 0.15)";
    ctx.lineWidth = 1;
    ctx.stroke();

    const illuminated = phase <= 0.5 ? phase * 2 : (1 - phase) * 2;
    const isWaxing = phase < 0.5;

    ctx.save();
    ctx.beginPath();
    ctx.arc(cx, cy, r, Math.PI / 2, -Math.PI / 2, false);
    const kx = r * (1 - illuminated * 2);
    ctx.bezierCurveTo(
      cx + (isWaxing ? kx : -kx), cy - r * 0.55,
      cx + (isWaxing ? kx : -kx), cy + r * 0.55,
      cx, cy + r
    );
    ctx.closePath();
    const grad = ctx.createRadialGradient(cx - r * 0.2, cy - r * 0.2, r * 0.1, cx, cy, r);
    grad.addColorStop(0,   "rgba(230, 245, 255, 0.95)");
    grad.addColorStop(0.6, "rgba(200, 230, 240, 0.85)");
    grad.addColorStop(1,   "rgba(160, 210, 230, 0.70)");
    ctx.fillStyle = grad;
    ctx.fill();
    ctx.restore();

    const glow = ctx.createRadialGradient(cx, cy, r, cx, cy, r + 12);
    glow.addColorStop(0, "rgba(34, 211, 238, 0.07)");
    glow.addColorStop(1, "rgba(34, 211, 238, 0)");
    ctx.beginPath();
    ctx.arc(cx, cy, r + 12, 0, Math.PI * 2);
    ctx.fillStyle = glow;
    ctx.fill();
  }

  const canvas = document.getElementById("moon-canvas") as HTMLCanvasElement;
  const nameEl = document.getElementById("moon-name") as HTMLElement;
  const { phase, name } = getMoonPhase(new Date());
  drawMoon(canvas, phase);
  if (nameEl) nameEl.textContent = name;
</script>

<style>
  .footer-icon {
    color: rgba(255, 255, 255, 0.28);
    transition: color 0.2s ease;
  }
  .footer-icon:hover { color: rgba(34, 211, 238, 0.9); }

  /* Bordes laterales de la quote solo en sm+ */
  .quote-box {
    padding: 0 1rem;
  }
  @media (min-width: 640px) {
    .quote-box {
      border-left: 1.5px solid rgba(34, 211, 238, 0.15);
      border-right: 1.5px solid rgba(34, 211, 238, 0.15);
    }
  }

  .quote-text   { color: rgba(34, 211, 238, 0.55); }
  .quote-author { color: rgba(255, 255, 255, 0.22); }

  .moon-widget {
    opacity: 0.85;
    transition: opacity 0.3s ease;
  }
  .moon-widget:hover { opacity: 1; }
</style>